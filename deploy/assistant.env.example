# Synapto — Telegram News Digest Assistant
#
# Example env file for a server deployment with the REAL Telegram bot and
# a real OpenAI-compatible AI provider. Copy to .runtime/assistant.env
# (or wherever your compose file points) and fill in the values.
#
# Never commit a populated copy of this file. .gitignore already covers
# .runtime/, .env, and *.env.local.

# --- AI provider ------------------------------------------------------------
# Switch the provider without rebuilding the image.
#   fake      : rule-based, no network (good for local sanity checks)
#   openai    : any OpenAI-compatible /v1/chat/completions endpoint
#   anthropic : any Anthropic Messages API compatible endpoint
#               (POST <AI_BASE_URL>/messages, x-api-key + anthropic-version)
ASSISTANT_AI_PROVIDER=anthropic

# Base URL the AI client will hit. The library appends /chat/completions
# (openai) or /messages (anthropic). Examples:
#   https://api.openai.com/v1                        (OpenAI)
#   https://opencode.ai/zen/go/v1                    (Anthropic-Messages via opencode)
#   https://api.anthropic.com/v1                     (Anthropic direct)
#   http://localhost:11434/v1                        (Ollama, openai-compat)
AI_BASE_URL=https://opencode.ai/zen/go/v1

AI_MODEL=minimax-m3

# Per-call timeout. AI summarization is the slowest step in a cycle; keep
# this well under DIGEST_INTERVAL.
AI_PER_CALL_TIMEOUT=15s

# Max in-flight summarizer calls. The cycle caps at 8 by default; raise
# for large windows if your provider can handle it.
AI_MAX_CONCURRENCY=8

# --- Telegram ---------------------------------------------------------------
# Bot token from @BotFather. The container's long-poll goroutine will use
# this to read channel_post events and to deliver digests.
TELEGRAM_BOT_TOKEN=replace-me

# Subscriber chat id. Leave at 0 and the service will auto-discover the
# chat id the first time the subscriber sends any message to the bot
# (e.g. /start), then persist it to the settings row.
TELEGRAM_SUBSCRIBER_CHAT=0

# Set to true to force the in-process fake Telegram client (local-only
# tests; no bot token required). Defaults to false.
TELEGRAM_USE_FAKE=false

# --- Cycle ------------------------------------------------------------------
# How often the digest loop runs. Min 1m, max 24h.
DIGEST_INTERVAL=10m

# --- Admin panel ------------------------------------------------------------
# HTTP bind address. Inside the container the safe default is 0.0.0.0:8080
# so the published port works. Override only if you know what you are doing.
ADMIN_LISTEN_ADDR=0.0.0.0:8080

# If set, the admin panel requires a login session. Recommended on any
# non-localhost bind. Empty disables auth (phase-1 default; do not expose
# publicly without setting this).
ADMIN_PASSWORD=

# --- Storage ----------------------------------------------------------------
# Inside the container, this path is on the synapto-data named volume.
DB_PATH=/data/assistant.db

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=info
