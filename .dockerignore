# Keep the build context small and the image free of secrets / dev state.
# Anything not needed for `docker build` belongs here.

# Version control
.git/
.gitignore
.gitattributes

# Local agent / IDE / spec-kit state
.opencode/
.specify/

# Runtime artifacts (DB, logs, sent messages) — never baked into an image
.runtime/
*.db
*.db-shm
*.db-wal
*.log
*.err

# Frontend build artifacts and dependencies — produced inside the image
frontend/build/
frontend/.svelte-kit/
frontend/.vite/
frontend/node_modules/

# Embedded SPA staging area — replaced by the SPA stage inside the image
backend/internal/adminapi/spa/_app/
backend/internal/adminapi/spa/index.html
backend/internal/adminapi/spa/favicon*

# Pre-built Go binaries (the Dockerfile builds its own)
bin/
backend/bin/
backend/assistant
backend/assistant.exe

# Local secrets and editor cruft
.env
.env.*
*.env.local
.vscode/
.idea/
.DS_Store
Thumbs.db

# Spec / docs / scripts (kept in the repo but irrelevant to the build)
docs/
specs/
scripts/
*.md
!backend/go.mod
